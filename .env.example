# DeepSeek-Super 环境变量
# 复制此文件为 .env 并修改配置

# 服务器端口
PORT=3001

# DeepSeek API Key（前端优先使用 localStorage 中的 key，此值作为后端默认值）
DEEPSEEK_API_KEY=sk-your-api-key-here

# 数据库路径（相对于 server/ 目录）
DB_PATH=./bbot.db

# 日志级别: debug | info | warn | error
LOG_LEVEL=info

# Agent 工作区根目录（默认用户主目录）
AGENT_WORKSPACE=

# 请求限流：每个 IP 每分钟最大请求数
RATE_LIMIT_MAX=100

# PaddleOCR 服务端口（图片文字识别）
OCR_PORT=19528

# PaddleOCR 模型缓存目录（留空自动选择，路径不要含中文）
# Windows: 默认 E:\paddleocr_models 或 C:\paddleocr_models
# Linux/Mac: 默认 ~/.paddleocr_models
PADDLEOCR_HOME=

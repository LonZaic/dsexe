# DeepSeek-Super 环境变量
# 复制此文件为 .env 并修改配置

# 服务器端口
PORT=3001

# DeepSeek API Key（前端优先使用 localStorage 中的 key，此值作为后端默认值）
DEEPSEEK_API_KEY=sk-your-api-key-here

# 数据库路径（相对于 server/ 目录）
DB_PATH=./bbot.db

# 日志级别: debug | info | warn | error
LOG_LEVEL=info

# Agent 工作区根目录（默认用户主目录）
AGENT_WORKSPACE=

# 请求限流：每个 IP 每分钟最大请求数
RATE_LIMIT_MAX=100

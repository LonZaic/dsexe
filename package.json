{
  "name": "deepseek-super",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "node server/index.js",
    "start": "node server/index.js",
    "electron": "electron .",
    "dist": "vite build && electron-builder --win",
    "dist:portable": "vite build && electron-builder --win portable"
  },
  "build": {
    "appId": "com.superds.app",
    "productName": "SuperDS",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "server/**/*",
      "electron/**/*",
      "node_modules/**/*",
      ".env.example"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "SuperDS",
      "uninstallDisplayName": "SuperDS"
    },
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/pdfjs-dist/**"
    ],
    "electronVersion": "33.3.1"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "axios": "^1.16.1",
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.6",
    "docx": "^9.7.1",
    "docxtemplater": "^3.68.7",
    "docxtemplater-image-module-free": "^1.1.1",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "gifenc": "^1.0.3",
    "highlight.js": "^11.11.1",
    "jszip": "^3.10.1",
    "marked": "^18.0.4",
    "marked-highlight": "^2.2.4",
    "nodemailer": "^8.0.10",
    "pdfjs-dist": "^6.0.227",
    "pdfkit": "^0.18.0",
    "pinia": "^3.0.4",
    "pizzip": "^3.2.0",
    "pptxgenjs": "^4.0.1",
    "sql.js": "^1.14.1",
    "tesseract.js": "^5.1.1",
    "uuid": "^14.0.0",
    "vue": "^3.5.34",
    "vue-router": "^4.6.4",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@vitejs/plugin-vue": "^6.0.6",
    "electron": "^33.3.1",
    "electron-builder": "^26.15.2",
    "vite": "^8.0.12"
  }
}
